# Required for database-backed features. The app uses DATABASE_URL first; the
# POSTGRES_URL variants below are supported fallbacks.
DATABASE_URL=

# Required for admin features. Both values must be set together.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Optional: required for local Vercel Blob uploads and deletes. Vercel-hosted
# deployments can obtain Blob access from the runtime automatically.
BLOB_READ_WRITE_TOKEN=

# Optional: Vercel/Neon-generated connection alternatives and parameters.
# They are not needed when DATABASE_URL is set.
DATABASE_URL_UNPOOLED=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=

# Optional: Vercel-managed metadata. These variables are not read directly by
# the application but may be populated by linked Vercel integrations.
VERCEL_OIDC_TOKEN=
BLOB_WEBHOOK_PUBLIC_KEY=
BLOB_STORE_ID=
