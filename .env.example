# Pooled connection for normal application queries. Local development and
# Vercel Preview should point this at the shared non-production Neon database.
DATABASE_URL=

# Direct connection preferred by db:migrate and db:migrate:status. Migration
# fallback order is DATABASE_URL_UNPOOLED, POSTGRES_URL_NON_POOLING,
# STORAGE_DATABASE_URL_UNPOOLED, then DATABASE_URL.
DATABASE_URL_UNPOOLED=

# Required for admin features. Set all three values together. The session secret
# must contain at least 32 UTF-8 bytes.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Optional: required for local Vercel Blob uploads and deletes. Vercel-hosted
# deployments can obtain Blob access from the runtime automatically.
BLOB_READ_WRITE_TOKEN=

# Optional: Vercel/Neon-generated connection alternatives and parameters.
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=

# Optional: Vercel-managed metadata. These variables are not read directly by
# the application but may be populated by linked Vercel integrations.
VERCEL_OIDC_TOKEN=
BLOB_WEBHOOK_PUBLIC_KEY=
BLOB_STORE_ID=
